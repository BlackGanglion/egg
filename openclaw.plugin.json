{
  "id": "openclaw-linear-agent",
  "name": "Linear Agent",
  "description": "Linear Agent Session integration — receive @mentions, run agents, stream results back to Linear",
  "configSchema": {
    "type": "object",
    "required": ["webhookSecret", "clientId", "clientSecret", "redirectUri"],
    "properties": {
      "webhookSecret": {
        "type": "string",
        "description": "Linear webhook signing secret (HMAC-SHA256)",
        "sensitive": true
      },
      "clientId": {
        "type": "string",
        "description": "Linear OAuth app client ID"
      },
      "clientSecret": {
        "type": "string",
        "description": "Linear OAuth app client secret",
        "sensitive": true
      },
      "redirectUri": {
        "type": "string",
        "description": "OAuth redirect URI (must match Linear OAuth app config)"
      },
      "tokenStorePath": {
        "type": "string",
        "description": "Path to store OAuth tokens (default: .data/oauth-token.json)"
      },
      "defaultDir": {
        "type": "string",
        "description": "Default working directory for agent execution"
      }
    }
  }
}
